{
  "extraKnownMarketplaces": {
    "tokenmaxxxer": {
      "source": {
        "source": "github",
        "repo": "tokenmaxxxer/claude-plugins"
      }
    }
  },
  "enabledPlugins": {
    "tokenmaxxxer-env@tokenmaxxxer": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/install-stack.sh"
          }
        ]
      }
    ]
  }
}
